# ── MATH ─────────────────────────────────────────────────────────────────────
def sip_fv(pmt, annual_rate, n_months):
    r = annual_rate / 12
    return pmt * ((pow(1 + r, n_months) - 1) / r) * (1 + r)

def fmt_inr(n, force_lakh=False):
    n = round(n)
    if n >= 100000 or force_lakh:
        return f"Rs. {n/100000:.2f}L"
    return f"Rs. {n:,}"

