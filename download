class GrowthChart(Flowable):
    """Simple line chart drawn with canvas"""
    def __init__(self, monthly, width, height=150):
        super().__init__()
        self.monthly = monthly; self.width = width; self.height = height
    def wrap(self, *args): return self.width, self.height
    def draw(self):
        c = self.canv
        c.saveState()
        pad_l = 52; pad_b = 22; pad_t = 10; pad_r = 14
        cw = self.width - pad_l - pad_r
        ch = self.height - pad_b - pad_t
        # Data points every 6 months
        pts_invested = []
        pts_portfolio = []
        x_labels = []
        for m in range(6, MONTHS+1, 6):
            pts_invested.append(self.monthly * m)
            pts_portfolio.append(sip_fv(self.monthly, 0.132, m))
            x_labels.append(f"Y{m//12}" if m % 12 == 0 else '')
        max_v = max(pts_portfolio) * 1.08
        def tx(i): return pad_l + cw * i / (len(pts_invested)-1)
        def ty(v): return pad_b + ch * v / max_v
        # Grid lines
        c.setStrokeColor(colors.HexColor('#eaeff6'))
        c.setLineWidth(0.4)
        for i in range(5):
            y = pad_b + ch * i / 4
            c.line(pad_l, y, pad_l + cw, y)
            v = max_v * i / 4
            c.setFillColor(INK_MUTED); c.setFont('Helvetica', 6)
            c.drawRightString(pad_l - 3, y - 2, fmt_inr(v))
        # Invested area fill
        path = c.beginPath()
        path.moveTo(tx(0), pad_b)
        for i, v in enumerate(pts_invested):
            path.lineTo(tx(i), ty(v))
        path.lineTo(tx(len(pts_invested)-1), pad_b)
        path.close()
        c.setFillColor(colors.HexColor('#e8eef8'))
        c.drawPath(path, fill=1, stroke=0)
        # Portfolio area fill
        path2 = c.beginPath()
        path2.moveTo(tx(0), pad_b)
        for i, v in enumerate(pts_portfolio):
            path2.lineTo(tx(i), ty(v))
        path2.lineTo(tx(len(pts_portfolio)-1), pad_b)
        path2.close()
        c.setFillColor(colors.HexColor('#d0dcea'))
        c.drawPath(path2, fill=1, stroke=0)
        # Invested line (dashed)
        c.setStrokeColor(GOLD)
        c.setLineWidth(1.2)
        c.setDash([4, 3])
        p = c.beginPath()
        for i, v in enumerate(pts_invested):
            if i == 0: p.moveTo(tx(i), ty(v))
            else: p.lineTo(tx(i), ty(v))
        c.drawPath(p, fill=0, stroke=1)
        # Portfolio line (solid)
        c.setStrokeColor(NAVY)
        c.setLineWidth(1.8)
        c.setDash([])
        p2 = c.beginPath()
        for i, v in enumerate(pts_portfolio):
            if i == 0: p2.moveTo(tx(i), ty(v))
            else: p2.lineTo(tx(i), ty(v))
        c.drawPath(p2, fill=0, stroke=1)
        # Dots on portfolio
        c.setFillColor(NAVY)
        for i, v in enumerate(pts_portfolio):
            c.circle(tx(i), ty(v), 2.2, fill=1, stroke=0)
        # X labels
        c.setFillColor(INK_MUTED); c.setFont('Helvetica', 6.5)
        for i, lbl in enumerate(x_labels):
            if lbl:
                c.drawCentredString(tx(i), pad_b - 12, lbl)
        # Legend
        lx = pad_l
        c.setFillColor(NAVY); c.rect(lx, self.height - pad_t - 8, 14, 4, fill=1, stroke=0)
        c.setFillColor(INK_SOFT); c.setFont('Helvetica', 6.5)
        c.drawString(lx + 17, self.height - pad_t - 7, 'Portfolio Value (~13.2% CAGR)')
        lx2 = lx + 150
        c.setStrokeColor(GOLD); c.setLineWidth(1); c.setDash([4,3])
        c.line(lx2, self.height - pad_t - 5, lx2 + 14, self.height - pad_t - 5)
        c.setDash([])
        c.setFillColor(INK_SOFT)
        c.drawString(lx2 + 17, self.height - pad_t - 7, 'Amount Invested')
        c.restoreState()

class RiskGauge(Flowable):
    def __init__(self, width):
        super().__init__()
        self.width = width
    def wrap(self, *args): return self.width, 28
    def draw(self):
        c = self.canv
        c.saveState()
        segs = 9
        active = [3, 4, 5, 6]
        seg_w = (self.width * 0.7) / segs
        gap = 2
        for i in range(segs):
            x = i * (seg_w + gap)
            col = GOLD if i in active else CREAM_D
            c.setFillColor(col)
            c.roundRect(x, 14, seg_w, 8, 2, fill=1, stroke=0)
        # Labels
        c.setFillColor(INK_MUTED); c.setFont('Helvetica', 6.5)
        c.drawString(0, 4, 'Conservative')
        mid_x = (self.width * 0.7) / 2
        c.setFillColor(GOLD); c.setFont('Helvetica-Bold', 6.5)
        c.drawCentredString(mid_x, 4, 'Moderate-High  (confirmed)')
        c.setFillColor(INK_MUTED); c.setFont('Helvetica', 6.5)
        c.drawRightString(self.width * 0.7, 4, 'Aggressive')
        c.restoreState()

