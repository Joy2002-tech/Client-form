class DonutChart(Flowable):
    def __init__(self, size=130):
        super().__init__()
        self.size = size
    def wrap(self, *args): return self.size, self.size
    def draw(self):
        c = self.canv
        c.saveState()
        cx, cy = self.size/2, self.size/2
        r_outer = self.size/2 - 4
        r_inner = r_outer * 0.62
        # Nifty 60% (216 deg from 90)
        # HDFC 40% (144 deg)
        slices = [
            (NAVY, 90, 90 + 216),    # 60% navy
            (GOLD, 90 + 216, 90 + 360),  # 40% gold
        ]
        for col, start, end in slices:
            path = c.beginPath()
            # outer arc
            path.moveTo(cx + r_outer * math.cos(math.radians(start)),
                        cy + r_outer * math.sin(math.radians(start)))
            # draw arc outer
            c.setFillColor(col)
            c.setStrokeColor(WHITE)
            c.setLineWidth(2)
            # Use wedge approach
        # Draw using wedge shapes
        import math
        for col, start_deg, end_deg in [
            (NAVY, 0, 216),
            (GOLD, 216, 360),
        ]:
            c.setFillColor(col)
            c.setStrokeColor(WHITE)
            c.setLineWidth(1.5)
            # Draw full wedge then mask inner
            start_r = math.radians(90 - start_deg)
            end_r = math.radians(90 - end_deg)
            pts = [(cx, cy)]
            steps = max(30, int(abs(end_deg - start_deg)))
            for i in range(steps + 1):
                angle = math.radians(90 - start_deg - (end_deg - start_deg) * i / steps)
                pts.append((cx + r_outer * math.cos(angle), cy + r_outer * math.sin(angle)))
            p = c.beginPath()
            p.moveTo(*pts[0])
            for pt in pts[1:]: p.lineTo(*pt)
            p.close()
            c.drawPath(p, fill=1, stroke=1)
        # White inner circle (donut hole)
        c.setFillColor(WHITE)
        c.setStrokeColor(WHITE)
        c.circle(cx, cy, r_inner, fill=1, stroke=0)
        # Centre text
        c.setFillColor(INK_MUTED)
        c.setFont('Helvetica', 6.5)
        c.drawCentredString(cx, cy + 6, 'Blended CAGR')
        c.setFillColor(INK)
        c.setFont('Helvetica-Bold', 12)
        c.drawCentredString(cx, cy - 6, '~13.2%')
        c.restoreState()

