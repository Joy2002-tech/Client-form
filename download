class HLine(Flowable):
    def __init__(self, width, color=BORDER, thickness=0.5, spaceAbove=4, spaceBelow=4):
        super().__init__()
        self.width = width; self.color = color; self.thickness = thickness
        self.spaceAbove = spaceAbove; self.spaceBelow = spaceBelow
    def wrap(self, *args): return self.width, self.thickness + self.spaceAbove + self.spaceBelow
    def draw(self):
        self.canv.saveState()
        self.canv.setStrokeColor(self.color)
        self.canv.setLineWidth(self.thickness)
        self.canv.line(0, self.spaceBelow, self.width, self.spaceBelow)
        self.canv.restoreState()

